{
  "expo": {
    "name": "NexaSphere Mobile",
    "slug": "nexasphere-mobile",
    "scheme": "nexasphere",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["react-native-reanimated/plugin"]
  }
}
