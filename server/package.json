{
  "name": "nexasphere-server",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "node index.js",
    "build": "echo \"server build step not required\"",
    "test": "node --test test/sanitize.test.js test/formSchemas.test.js test/adminSessions.test.js test/notificationsService.test.js test/notificationSubscription.test.js test/sql-injection.test.js test/xss.test.js test/cors.test.js test/tierRateLimiter.test.js test/sync.test.js test/activityEventsService.test.js test/metrics.test.js test/logger.test.js test/observabilityInit.test.js test/tracing.test.js test/performanceMonitor.test.js test/errorTracking.test.js",
    "test:watch": "node --test --watch test/sanitize.test.js test/formSchemas.test.js test/adminSessions.test.js test/notificationsService.test.js test/notificationSubscription.test.js test/sql-injection.test.js test/xss.test.js test/cors.test.js test/tierRateLimiter.test.js test/sync.test.js test/activityEventsService.test.js test/metrics.test.js test/logger.test.js test/observabilityInit.test.js test/tracing.test.js test/performanceMonitor.test.js test/errorTracking.test.js",
    "migrate": "node-pg-migrate -f .postgres_migrations_config.json",
    "migrate:latest": "node-pg-migrate -f .postgres_migrations_config.json up",
    "migrate:rollback": "node-pg-migrate -f .postgres_migrations_config.json down",
    "migrate:reset": "node-pg-migrate -f .postgres_migrations_config.json reset",
    "migrate:create": "node-pg-migrate -f .postgres_migrations_config.json create",
    "db:validate": "node scripts/validate-database.js",
    "audit:sql": "node scripts/audit-sql.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@sendgrid/mail": "^8.1.3",
    "@sentry/node": "8.55.2",
    "@sentry/profiling-node": "8.55.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "async-mutex": "^0.5.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ejs": "^5.0.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.0.0",
    "firebase-admin": "^12.0.0",
    "googleapis": "^140.0.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "isomorphic-dompurify": "3.16.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.21.0",
    "prom-client": "^15.1.2",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "redoc-express": "^1.0.0",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.3.4",
    "zod": "^4.4.3"
  }
