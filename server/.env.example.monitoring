# =====================================================
# Error Logging & Monitoring Configuration
# =====================================================

# --------- SENTRY CONFIGURATION ---------
# Get your DSN from: https://sentry.io/

# Frontend Sentry DSN
VITE_SENTRY_DSN=your_frontend_sentry_dsn_here

# Backend Sentry DSN
SENTRY_DSN=your_backend_sentry_dsn_here

# Sentry Environment
SENTRY_ENVIRONMENT=development

# --------- WINSTON LOGGER CONFIGURATION ---------
# Log level: error, warn, info, http, debug
LOG_LEVEL=info

# --------- SLACK INTEGRATION ---------
# Get your webhook URL from: https://api.slack.com/apps/
# Format: https://hooks.slack.com/services/YOUR/WEBHOOK/URL

SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Slack alert threshold for error rate (percentage)
ERROR_RATE_THRESHOLD=5

# --------- PERFORMANCE MONITORING ---------
# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# Slow request threshold (milliseconds)
SLOW_REQUEST_THRESHOLD=1000

# --------- ERROR TRACKING ---------
# Enable error tracking
ENABLE_ERROR_TRACKING=true

# Maximum number of errors to store in memory
MAX_ERRORS_IN_MEMORY=1000

# --------- NODE ENVIRONMENT ---------
NODE_ENV=development

# Application environment
APP_ENV=development

# =====================================================
# PRODUCTION NOTES
# =====================================================
# 1. In production, ensure all DSNs are properly configured
# 2. Set NODE_ENV=production to disable verbose logging
# 3. Use LOG_LEVEL=warn or error in production
# 4. Enable Slack alerts for critical errors
# 5. Monitor error rate thresholds closely
# 6. Consider using a database for long-term error storage
# =====================================================
