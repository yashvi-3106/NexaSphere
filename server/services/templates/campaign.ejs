<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #0f172a; margin: 0; padding: 0; }
  .wrapper { width: 100%; table-layout: fixed; background-color: #0f172a; padding: 40px 0; }
  .container { max-width: 600px; margin: 0 auto; background-color: #1e293b; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3); border: 1px solid #334155; }
  .header { padding: 32px; text-align: center; background-color: #0f172a; border-bottom: 1px solid #334155; }
  .logo { font-size: 28px; font-weight: 700; color: #f8fafc; margin: 0; letter-spacing: -0.5px; }
  .logo-highlight { color: #3b82f6; }
  .content { padding: 40px 32px; color: #cbd5e1; line-height: 1.6; }
  h1 { font-size: 24px; color: #f8fafc; margin-top: 0; font-weight: 600; }
  h2 { font-size: 20px; color: #f8fafc; font-weight: 600; }
  p { margin-bottom: 24px; font-size: 16px; }
  .btn-container { text-align: center; margin: 32px 0; }
  .button { display: inline-block; padding: 14px 28px; background-color: #3b82f6; color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; }
  .button-secondary { display: inline-block; padding: 10px 20px; background-color: transparent; color: #3b82f6 !important; text-decoration: none; border-radius: 8px; font-weight: 500; font-size: 14px; border: 1px solid #3b82f6; }
  .feature-list { list-style: none; padding: 0; margin: 24px 0; }
  .feature-list li { padding: 12px 0; border-bottom: 1px solid #334155; color: #cbd5e1; font-size: 15px; }
  .feature-list li:last-child { border-bottom: none; }
  .feature-icon { color: #3b82f6; margin-right: 8px; }
  .cta-section { background-color: #0f172a; padding: 32px; text-align: center; border-top: 1px solid #334155; }
  .footer { background-color: #0f172a; padding: 24px; text-align: center; font-size: 14px; color: #64748b; border-top: 1px solid #334155; }
  .footer a { color: #64748b; text-decoration: underline; }
</style>
</head>
<body>
  <div class="wrapper">
    <div class="container">
      <div class="header">
        <h2 class="logo">Nexa<span class="logo-highlight">Sphere</span></h2>
      </div>
      <div class="content">
        <h1>Hello <%= name %>!</h1>
        <div>
          <%= content.body || '' %>
        </div>
      </div>
      <% if (content.buttonText && content.buttonUrl) { %>
      <div class="cta-section">
        <div class="btn-container">
          <a href="<%= content.buttonUrl %>" class="button"><%= content.buttonText %></a>
        </div>
      </div>
      <% } %>
      <div class="footer">
        <p>&copy; <%= new Date().getFullYear() %> NexaSphere. All rights reserved.</p>
        <p><a href="<%= unsubscribeUrl %>">Unsubscribe from these emails</a></p>
      </div>
    </div>
  </div>
</body>
</html>
