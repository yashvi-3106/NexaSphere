# NexaSphere Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.

# Server
PORT=8787
NODE_ENV=development
# CORS_ORIGIN: comma-separated list of allowed frontend origins.
# Development: http://localhost:5175 (website) and http://localhost:5001 (admin)
CORS_ORIGIN=http://localhost:5175,http://localhost:5001
# Canonical public URL for building email verification and other app links
PUBLIC_APP_URL=http://localhost:5175
# Alias for PUBLIC_APP_URL (used in some integrations)
FRONTEND_URL=http://localhost:5175

# PostgreSQL direct connection (used by admin sessions and portfolio repository)
DATABASE_URL=

# PostgreSQL connection pool tuning — all optional, sensible defaults shown.
# PG_POOL_MAX: max simultaneous connections (default 20)
PG_POOL_MAX=20
# PG_CONNECTION_TIMEOUT_MS: ms to wait for a free slot before throwing (default 5000)
PG_CONNECTION_TIMEOUT_MS=5000
# PG_IDLE_TIMEOUT_MS: ms an idle connection stays open before being closed (default 30000)
PG_IDLE_TIMEOUT_MS=30000
# PG_STATEMENT_TIMEOUT_MS: per-query execution ceiling sent to Postgres (default 10000)
PG_STATEMENT_TIMEOUT_MS=10000

# Database & Authentication (Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Admin Authentication
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=ChangeMe123!Dev
ADMIN_EVENT_PASSWORD=ChangeMe123!Event

# Email Provider Configuration (Nodemailer / Resend / SendGrid)
# For standard SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here

# Default From Address for outbound emails
EMAIL_FROM="NexaSphere Team" <noreply@nexasphere.com>

# Google Services (For Forms/Sheets)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB_NAME=Responses
GOOGLE_MEMBERSHIP_TAB_NAME=MembershipResponses
GOOGLE_RECRUITMENT_TAB_NAME=RecruitmentResponses
GOOGLE_CORE_TEAM_TAB_NAME=CoreTeamResponses

# Membership Google Apps Script (Server-side only — never expose to client)
MEMBERSHIP_SCRIPT_URL=
MEMBERSHIP_SECRET=

# Student OAuth / SSO (Google + GitHub)
# Google OAuth — restrict to @glbajajgroup.org domain via OAUTH_DOMAIN_RESTRICTION
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Domain restriction for OAuth (e.g., "glbajajgroup.org" — leave empty for no restriction)
OAUTH_DOMAIN_RESTRICTION=
# JWT secret for student tokens (use a long random string in production)
JWT_SECRET=nexasphere-jwt-dev-secret-change-in-production
# JWT token expiry (default 7d)
JWT_EXPIRY=7d
# Base URL for OAuth callbacks (defaults to http://localhost:8080)
BASE_URL=http://localhost:8080

# Notification API Key (optional — if set, /api/notifications/subscribe and /unsubscribe require it via x-notification-key header)
NOTIFICATIONS_API_KEY=

# Error Tracking buffer capacity limit
ERROR_BUFFER_LIMIT=1000

# Data Backup & Disaster Recovery Config
ENCRYPTION_KEY=your-backup-encryption-aes-key

# Primary S3 Storage Config
S3_ENDPOINT=https://your-primary-s3-endpoint.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-primary-access-key-id
S3_SECRET_ACCESS_KEY=your-primary-secret-access-key
S3_BUCKET_NAME=your-primary-bucket-name

# Secondary S3 Storage Config (Geographic Redundancy)
S3_ENDPOINT_SECONDARY=https://your-secondary-s3-endpoint.com
S3_REGION_SECONDARY=us-west-2
S3_ACCESS_KEY_ID_SECONDARY=your-secondary-access-key-id
S3_SECRET_ACCESS_KEY_SECONDARY=your-secondary-secret-access-key
S3_BUCKET_NAME_SECONDARY=your-secondary-bucket-name

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8787/api/slack/auth/callback

# .env.example

ADMIN_PASSWORD=REQUIRED_MIN_12_CHARS
ADMIN_EVENT_PASSWORD=REQUIRED_MIN_12_CHARS
SESSION_SECRET=REQUIRED_MIN_12_CHARS
