datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String?
  password         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workspaceMembers WorkspaceMember[]
  posts            Post[]
  logs             Log[]
  feedbacks        EventFeedback[]
  actionItems      ActionItem[]
  settingsChanges  SettingsChangeLog[]
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  roles     Role[]
  posts     Post[]
  logs      Log[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  roleId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id])

  @@unique([workspaceId, userId])
}

model Role {
  id          String   @id @default(uuid())
  name        String
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  permissions Permission[]      @relation("RolePermissions")
  members     WorkspaceMember[]

  @@unique([name, workspaceId])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles Role[] @relation("RolePermissions")
}

model Post {
  id          String   @id @default(uuid())
  title       String
  content     String?
  published   Boolean  @default(false)
  authorId    String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Log {
  id          String   @id @default(uuid())
  action      String
  details     String?
  userId      String?
  workspaceId String
  createdAt   DateTime @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String      @id @default(uuid())
  actorId   String
  action    AuditAction
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?

  timestamp DateTime    @default(now())
}

model EventFeedback {
  id               String   @id @default(uuid())
  eventId          String
  userId           String?
  ratingOverall    Int
  wouldAttendAgain Boolean?
  recommendFriend  Boolean?
  ratingVenue      Int?
  ratingContent    Int?
  ratingSpeaker    Int?
  ratingPace       Int?
  suggestions      String?
  bestParts        String?
  sentiment        String?  @default("neutral")
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ActionItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("pending")
  assigneeId  String?
  eventId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee User? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model PlatformSetting {
  id          String   @id @default(cuid())
  environment String   @default("development")
  key         String
  value       String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([environment, key], name: "environment_key")
  @@index([environment])
}

model SettingsChangeLog {
  id            String   @id @default(cuid())
  environment   String
  key           String
  previousValue String?  @db.Text
  newValue      String   @db.Text
  isRollback    Boolean  @default(false)
  changedById   String?
  changedBy     User?    @relation(fields: [changedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([environment, key])
  @@index([changedById])
}

model EventPricing {
  id            String         @id @default(uuid())
  eventId       String         @unique
  basePrice     Float
  currentPrice  Float
  minPrice      Float
  maxPrice      Float
  capacity      Int
  registrations Int            @default(0)
  eventDate     DateTime
  adminOverride Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  priceHistory  PriceHistory[]
}

model PriceHistory {
  id        String   @id @default(uuid())
  pricingId String
  price     Float
  reason    String
  createdAt DateTime @default(now())

  pricing   EventPricing @relation(fields: [pricingId], references: [id], onDelete: Cascade)
}
