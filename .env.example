# ── Frontend (Vite) ──────────────────────────────────────────────────────────

# Base URL of the backend API (e.g., http://localhost:8787 or https://api.example.com)
# Leave empty to use offline/localStorage mock mode for development without backend
# Required: No (optional for offline development)
VITE_API_BASE=

# Google Apps Script deployment URL for membership form submissions
# Obtain from Google Apps Script > Deploy > Web App > Current web app URL
# Required: No (membership form shows offline warning if empty)
VITE_MEMBERSHIP_SCRIPT_URL=

# Secret token sent with membership form submissions to verify origin and prevent spam
# Generate a random string (e.g., using: openssl rand -hex 32)
# Required: No (but recommended for production security)
VITE_MEMBERSHIP_SECRET=

# VAPID public key for web push notification subscription
# Generate using web-push generate-vapid-keys command
# Required: No (push notifications disabled if empty)
VITE_VAPID_PUBLIC_KEY=

# Base path override for GitHub Pages or custom domain deployments
# Default: / (root path)
# Set to /repo-name for GitHub Pages deployments
# Required: No (uses default if not set)
VITE_BASE_PATH=/


# ── Admin Dashboard (admin-dashboard/) ───────────────────────────────────────

# Backend API base URL for admin operations (e.g., http://localhost:8787)
# Leave empty to use offline mock mode for development without backend
# Required: No (optional for offline development)
VITE_API_BASE=

# URL of the main frontend app — used to resolve team member photo assets
# Should match the deployed frontend URL (e.g., https://nexasphere-glbajaj.vercel.app)
# Required: Yes (for proper asset loading in admin dashboard)
VITE_MAIN_APP_URL=https://nexasphere-glbajaj.vercel.app

# Google Apps Script URL for live membership data in the admin dashboard
# Obtain from Google Apps Script > Deploy > Web App > Current web app URL
# Required: No (membership data shows offline warning if empty)
VITE_MEMBERSHIP_SCRIPT_URL=


# ── Backend (server/) ────────────────────────────────────────────────────────

# PostgreSQL connection string for the database
# Format: postgresql://user:password@host:port/database
# For local development: postgresql://postgres:password@localhost:5432/nexasphere
# For production: Use Supabase or managed PostgreSQL connection string
# Required: Yes (backend will not start without database connection)
DATABASE_URL=postgresql://user:password@localhost:5432/nexasphere

# CORS allowed origins (comma-separated list of URLs)
# Include all frontend URLs that will make API requests to this backend
# Local development: http://localhost:5173,http://localhost:5175,http://localhost:5001
# Production: https://your-frontend-domain.com
# Required: Yes (for API to accept requests from frontend)
CORS_ORIGIN=http://localhost:5173,https://nexasphere-glbajaj.vercel.app

# Sentry error tracking DSN (Data Source Name)
# Obtain from Sentry project settings > Client Keys (DSN)
# Required: No (error tracking disabled if empty)
SENTRY_DSN=

# Sentry organization slug
# Obtain from Sentry organization settings
# Required: No (only if using Sentry)
SENTRY_ORG=

# Sentry project slug
# Obtain from Sentry project settings
# Required: No (only if using Sentry)
SENTRY_PROJECT=

# Sentry authentication token for releasing deployments
# Obtain from Sentry > User Settings > Auth Tokens
# Required: No (only if using Sentry release tracking)
SENTRY_AUTH_TOKEN=

# Upstash Redis REST API URL for rate limiting and caching
# Obtain from Upstash console > Redis Database > REST API
# Required: No (rate limiting disabled if empty)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST API token for authentication
# Obtain from Upstash console > Redis Database > REST API
# Required: No (only if using Upstash Redis)
UPSTASH_REDIS_REST_TOKEN=

# Google Gemini API Key for AI Resume Parsing and recommendation engine
# Obtain from Google AI Studio > API Keys
# Required: No (AI features disabled if empty)
GEMINI_API_KEY=

# Encryption key for sensitive settings stored in database
# Generate a random 32-character string (e.g., using: openssl rand -hex 32)
# Required: Yes (for secure settings storage)
SETTINGS_ENCRYPTION_KEY=
# ── Notes ────────────────────────────────────────────────────────────────────
# VITE_API_BASE empty    → app runs in offline mode (localStorage mock DB)
# VITE_MEMBERSHIP_SCRIPT_URL empty → membership form shows "offline" warning in admin
# Admin dashboard is a separate Vite project (admin-dashboard/) with its own .env
