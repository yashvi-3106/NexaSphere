# ── Frontend (Vite) ──────────────────────────────────────────────────────────

# Base URL of the backend API (leave empty to use offline/localStorage mock mode)
VITE_API_BASE=

# Google Apps Script deployment URL for membership form submissions
VITE_MEMBERSHIP_SCRIPT_URL=

# Secret token sent with membership form submissions to verify origin
VITE_MEMBERSHIP_SECRET=

# VAPID public key for push notification subscription
VITE_VAPID_PUBLIC_KEY=

# Optional: Base path override for GitHub Pages deployments (default: /)
VITE_BASE_PATH=/


# ── Admin Dashboard (admin-dashboard/) ───────────────────────────────────────

# Backend API base URL for admin operations (leave empty for offline mock)
VITE_API_BASE=

# URL of the main frontend app — used to resolve team member photo assets
VITE_MAIN_APP_URL=https://nexasphere-glbajaj.vercel.app

# Google Apps Script URL for live membership data in the admin dashboard
VITE_MEMBERSHIP_SCRIPT_URL=


# ── Backend (server/) ────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/nexasphere

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,https://nexasphere-glbajaj.vercel.app

# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Gemini API Key for AI Resume Parsing and recommendation engine
GEMINI_API_KEY=


# ── Notes ────────────────────────────────────────────────────────────────────
# VITE_API_BASE empty    → app runs in offline mode (localStorage mock DB)
# VITE_MEMBERSHIP_SCRIPT_URL empty → membership form shows "offline" warning in admin
# Admin dashboard is a separate Vite project (admin-dashboard/) with its own .env
