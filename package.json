{
  "name": "nexasphere-monorepo",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "NexaSphere — GL Bajaj Tech Community Platform. Monorepo containing the website, admin dashboard, and server.",
  "workspaces": [
    "website",
    "admin-dashboard"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace=website",
    "dev:website": "npm run dev --workspace=website",
    "dev:admin": "npm run dev --workspace=admin-dashboard",
    "dev:server": "cd server && node index.js",
    "dev:all": "concurrently \"npm run dev:website\" \"npm run dev:admin\" \"npm run dev:server\"",
    "build": "npm run build --workspace=website",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test accessibility.spec.js",
    "build:website": "npm run build --workspace=website",
    "build:admin": "npm run build --workspace=admin-dashboard",
    "build:all": "npm run build:website && npm run build:admin",
    "preview": "npm run preview --workspace=website",
    "preview:admin": "npm run preview --workspace=admin-dashboard",
    "test": "npm run test --workspace=website",
    "test:admin": "npm run test --workspace=admin-dashboard",
    "test:server": "cd server && npm test",
    "lint": "eslint website/src --ext .js,.jsx",
    "lint:fix": "eslint website/src --ext .js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "echo 'No TypeScript in this project' && exit 0",
    "prepare": "node -e \"try { require('husky'); require('child_process').execSync('husky', {stdio:'inherit'}) } catch(e) { console.log('husky not available, skipping') }\""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "concurrently": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.3",
    "prisma": "^5.12.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-arm64-gnu": "1.0.3",
    "@rolldown/binding-linux-x64-gnu": "1.0.3",
    "@rolldown/binding-linux-x64-musl": "1.0.3",
    "@rollup/rollup-linux-arm64-gnu": "4.61.1",
    "@rollup/rollup-linux-arm64-musl": "4.60.0",
    "@rollup/rollup-linux-x64-gnu": "4.60.0",
    "@rollup/rollup-linux-x64-musl": "4.60.0",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-x64-musl": "1.32.0"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "jwt-decode": "^4.0.0",
    "lru-cache": "^11.5.1",
    "next-intl": "^4.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.0.0",
    "qrcode": "^1.5.3",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^2.0.1",
    "html5-qrcode": "^2.3.8"
  }
}
