{
  "index_patterns": ["nexasphere-compliance-*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.lifecycle.name": "nexasphere-compliance-365d",
      "index.lifecycle.rollover_alias": "nexasphere-compliance"
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "level": { "type": "keyword" },
        "message": { "type": "text" },
        "service": { "type": "keyword" },
        "reqId": { "type": "keyword" },
        "traceId": { "type": "keyword" },
        "userId": { "type": "keyword" }
      }
    }
  },
  "priority": 200
}
