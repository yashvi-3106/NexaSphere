diff --git a/admin-dashboard/src/components/PermissionGuard.jsx b/admin-dashboard/src/components/PermissionGuard.jsx
new file mode 100644
index 00000000..db727d2b
--- /dev/null
+++ b/admin-dashboard/src/components/PermissionGuard.jsx
@@ -0,0 +1,10 @@
+import React from 'react';
+import { auth } from '../services/auth';
+
+export function PermissionGuard({ requiredScope, children, fallback = null }) {
+  const scopes = auth.getScopes();
+  if (scopes.includes(requiredScope)) {
+    return <>{children}</>;
+  }
+  return fallback;
+}
