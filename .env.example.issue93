# ============================================================================
# Issue #93: Real-Time Features Environment Variables
# ============================================================================

# ============================================================================
# 1. WebSocket & Socket.IO Configuration
# ============================================================================

# Frontend URL for WebSocket connections
FRONTEND_URL=http://localhost:5173

# Socket.IO reconnection settings (optional, defaults apply if not set)
SOCKET_IO_RECONNECTION_ATTEMPTS=5
SOCKET_IO_RECONNECTION_DELAY=1000

# ============================================================================
# 2. Firebase Cloud Messaging (Push Notifications)
# ============================================================================

# Firebase project configuration
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase service account JSON (get from Firebase Console)
# This should be the entire JSON content as a string
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project","private_key_id":"key-id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# VAPID keys for Web Push (generate with: web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=BExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase API key for frontend (public)
REACT_APP_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# 3. SendGrid Email Service
# ============================================================================

# SendGrid API key (get from SendGrid dashboard)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid sender email address
SENDGRID_FROM_EMAIL=noreply@nexasphere.com

# Alternative SMTP configuration (if not using SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="NexaSphere Team <noreply@nexasphere.com>"

# ============================================================================
# 4. Push Notification Settings
# ============================================================================

# Enable/disable push notifications
ENABLE_PUSH_NOTIFICATIONS=true

# Push notification icon URLs
PUSH_NOTIFICATION_ICON=/pwa-192x192.png
PUSH_NOTIFICATION_BADGE=/pwa-192x192.png

# ============================================================================
# 5. Real-Time Event Configuration
# ============================================================================

# Enable/disable real-time features
ENABLE_WEBSOCKET=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SSE_STREAM=true

# Event reminder timing (in hours before event)
EVENT_REMINDER_HOURS=24

# Maximum concurrent WebSocket connections
MAX_WEBSOCKET_CONNECTIONS=1000

# ============================================================================
# 6. Admin SSE Stream Configuration
# ============================================================================

# Enable admin real-time stream
ENABLE_ADMIN_STREAM=true

# SSE heartbeat interval (milliseconds)
SSE_HEARTBEAT_INTERVAL=30000

# SSE connection timeout (milliseconds)
SSE_TIMEOUT=300000

# ============================================================================
# 7. Development/Production Settings
# ============================================================================

NODE_ENV=development
# NODE_ENV=production

# Enable detailed logging (development only)
DEBUG=true

# Log level: error, warn, info, http, debug
LOG_LEVEL=debug

# ============================================================================
# 8. Database Configuration (for storing subscriptions/tokens)
# ============================================================================

# Database connection for storing push subscriptions
DATABASE_URL=postgresql://user:password@localhost:5432/nexasphere

# ============================================================================
# 9. Frontend Environment (.env.local)
# ============================================================================

# Add these to your .env.local file in the frontend:

# REACT_APP_API_URL=http://localhost:3000
# REACT_APP_VAPID_PUBLIC_KEY=your-vapid-public-key
# REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
# REACT_APP_ENABLE_PUSH_NOTIFICATIONS=true

# ============================================================================
# 10. Setup Instructions
# ============================================================================

# Firebase Setup:
# 1. Create Firebase project at https://console.firebase.google.com
# 2. Enable Cloud Messaging in project settings
# 3. Download service account JSON from "Service Accounts" tab
# 4. Convert JSON to single-line string for FIREBASE_SERVICE_ACCOUNT
# 5. Get VAPID keys: npm install -g web-push && web-push generate-vapid-keys

# SendGrid Setup:
# 1. Sign up at https://sendgrid.com
# 2. Create API key with Mail Send permission
# 3. Verify sender email in settings
# 4. Add API key to SENDGRID_API_KEY

# Web Push Setup:
# 1. Generate VAPID keys: web-push generate-vapid-keys
# 2. Add to environment variables
# 3. Store public key in frontend config
# 4. Subscribe users with public key in browser

# ============================================================================
# 11. Testing Configuration
# ============================================================================

# Test Firebase messaging (requires valid credentials)
FIREBASE_TESTING_ENABLED=false

# Test email sending (development uses mock mailer if not configured)
EMAIL_TESTING_ENABLED=false

# Test WebSocket connections
WEBSOCKET_TESTING_ENABLED=true

# ============================================================================
# Example: Complete Production Setup
# ============================================================================

# NODE_ENV=production
# FRONTEND_URL=https://nexasphere.com
# FIREBASE_PROJECT_ID=nexasphere-prod
# FIREBASE_SERVICE_ACCOUNT='...' (full JSON)
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM_EMAIL=noreply@nexasphere.com
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# DATABASE_URL=postgresql://user:pass@prod-db.com/nexasphere
# LOG_LEVEL=info
# DEBUG=false
